# ── Required ───────────────────────────────────────────────────────────────
# Lidarr connection
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your-lidarr-api-key

# Defaults used when lidseeker adds an artist to Lidarr
ROOT_FOLDER_PATH=/music
QUALITY_PROFILE_ID=1            # Lidarr quality profile id (1 = Any)
METADATA_PROFILE_ID=1          # Lidarr metadata profile id (1 = Standard)
TRIGGER_ALBUM_SEARCH=true      # also fire Lidarr's AlbumSearch on request

# Auth — these bootstrap the FIRST ADMIN account on first start. Add more users
# in-app afterwards (Settings → Users); each person sees only their own requests.
# Set APP_PASSWORD (plaintext, hashed at startup) — simplest. Or pre-compute a
# bcrypt hash into APP_PASS_HASH (wins if both are set):
#   docker run --rm ghcr.io/ivorycobra-vc/lidseeker python -c "import bcrypt; print(bcrypt.hashpw(b'CHANGE_ME', bcrypt.gensalt()).decode())"
APP_USER=admin
APP_PASSWORD=
APP_PASS_HASH=
# JWT_SECRET signs login tokens. Leave it blank and lidseeker generates a strong
# random secret on first start and persists it to <data dir>/.jwt_secret (so you
# stay logged in across restarts) — set it explicitly only to pin a known value.
JWT_SECRET=
JWT_TTL_HOURS=48              # token lifetime (2 days); password change / delete revokes sooner

# Server
PORT=5056
DB_PATH=/data/lidseeker.db

# ── Hardening (recommended when exposing lidseeker to the internet) ─────────
# See docker-compose.tls.yml for a one-command HTTPS reverse proxy (Caddy).
# Behind any reverse proxy, set TRUST_PROXY=true so the login rate-limiter sees
# the real client IP (via X-Forwarded-For) instead of the proxy's.
TRUST_PROXY=false
# Send HSTS (force HTTPS for a year). Turn on only when always served over HTTPS.
SECURITY_HSTS=false
# Brute-force protection on the login endpoint: failed attempts per IP per window.
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# ── Optional: Soularr + slskd adapter ──────────────────────────────────────
# Only needed if you fulfil downloads via Soularr + slskd (Soulseek). Leave the
# slskd key blank and lidseeker runs in "Lidarr-native" mode: it reads download
# progress straight from Lidarr's queue, so it works with any Lidarr download
# client (SABnzbd, qBittorrent, NZBGet, …). See docker-compose.soularr.yml.
#
# SOULARR_ENABLED is auto-detected (on when SLSKD_API_KEY is set AND the Soularr
# config path is readable); set it explicitly to force on/off.
# SOULARR_ENABLED=
SLSKD_URL=http://localhost:5030
SLSKD_API_KEY=
SOULARR_CONTAINER=soularr
DOCKER_PROXY_URL=http://127.0.0.1:2375
SOULARR_CONFIG_PATH=/soularr/config.ini
SOULARR_DENYLIST_PATH=/soularr/failed_imports.json

# ── Optional: push notifications (ntfy) ────────────────────────────────────
# Fires a push when a request becomes available. Works with the public ntfy.sh
# or a self-hosted instance (e.g. https://ntfy.example.com). Pick a long, random
# topic — anyone who knows it can read your notifications.
NTFY_URL=
NTFY_TOPIC=

# ── Optional: "Open in" service links shown under a request in the app ──────
# Comma-separated Name|url pairs. Example uses a Tailscale 100.x address:
# SERVICE_LINKS=Lidarr|http://100.x.y.z:8686,slskd|http://100.x.y.z:5030
SERVICE_LINKS=

# ── Optional: contact string for the MusicBrainz API User-Agent ────────────
# MusicBrainz asks API clients to identify themselves. Point this at your fork.
# MUSICBRAINZ_CONTACT=lidseeker ( https://github.com/your-user/lidseeker )
